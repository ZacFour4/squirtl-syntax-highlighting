{
"scopeName": "source.squirtl",
"patterns": [
	{ "include": "#comments" },
	{ "include": "#keywords" },
	{ "include": "#strings" },
	{ "include": "#numbers" },
	{ "include": "#functions" },
	{ "include": "#types" },
	{ "include": "#variables" },
	{ "include": "#operators" },
	{ "include": "#directives" },
	{ "include": "#uris" }
],
"repository": {
	"comments": {
	"patterns": [
		{
			"match": "#.*$",
			"name": "comment.line.double-slash.squirtl"
		},
		{
			"begin": "\\{",
			"end": "\\}",
			"name": "comment.block.squirtl"
		}
	]
	},

	"keywords": {
	"patterns": [
		{
		"match": "\\b(SELECT|GROUP|USING|WHERE|JOIN|SELFJOIN|ON|UNION|INTERSECTION|DIFFERENCE)\\b",
		"name": "keyword.control.squirtl"
		},
		{
		"match": "\\b(AS)\\b",
		"name": "keyword.declaration.squirtl"
		}
	]
	},

	"strings": {
	"patterns": [
		{
		"begin": "\"",
		"end": "\"",
		"name": "string.quoted.double.squirtl"
		},
		{
		"begin": "<",
		"end": ">",
		"name": "string.quoted.single.squirtl"
		}
	]
	},

	"numbers": {
	"patterns": [
		{
		"match": "\\b\\d+\\b",
		"name": "constant.numeric.squirtl"
		}
	]
	},

	"functions": {
	"patterns": [
		{
		"match": "\\b(NOT|AND|XOR|OR|MAX|IS|SUM|MIN|AVG|COUNT|COUNTDISTINCT|PARITY|MODULO|SQUARE|TO_STRING|TO_INT|TO_URI|EXTEND_URI|POW|DIV|CONCAT|LENGTH|SUBSTRING|UPPER|LOWER|TRIM|CONTAINS|STARTSWITH|ENDSWITH)\\b",
		"name": "entity.name.function.squirtl"
		}
	]
	},

	"types": {
	"patterns": [
		{
		"match": "\\b(INTEGER|STRING|URI)\\b",
		"name": "entity.name.type.squirtl"
		}
	]
	},

	"variables": {
	"patterns": [
		{
		"match": "\\b\\?(subject|object|predicate)\\b",
		"name": "variable.language.squirtl"
		},
		{
		"match": "\\?[a-zA-Z_][a-zA-Z0-9_\\.]*",
		"name": "variable.other.squirtl"
		}
	]
	},

	"operators": {
	"patterns": [
		{
		"match": "[+\\-*/=<>!]+",
		"name": "keyword.operator.squirtl"
		},
		{
		"match": "[()]",
		"name": "punctuation.bracket.squirtl"
		},
		{
		"match": "[,;]",
		"name": "punctuation.separator.squirtl"
		}
	]
	},

	"filenames": {
		"patterns": [{
			"match": "\\b[a-zA-Z0-9_./-]+\\.ttl\\b",
			"name": "entity.name.filename.squirtl"
		}]
	},
	"directives": {
    "patterns": [
        {
            "match": "^%.*$",
            "name": "meta.preprocessor.squirtl"
        }
    ]
}
}
}